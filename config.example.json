{
  "enabled": true,
  "target_language": "zh-CN",
  "source_language": "auto",
  "provider": "google",
  "popup_seconds": 8,
  "min_text_length": 2,
  "max_text_length": 4000,
  "debounce_ms": 700,
  "restore_clipboard": true,
  "show_original": true,
  "skip_chinese": false,
  "ocr_enabled": false,
  "ocr_engine": "tesseract",
  "openai_model": "gpt-4.1-mini",
  "deepl_api_key_env": "DEEPL_API_KEY",
  "openai_api_key_env": "OPENAI_API_KEY"
}
